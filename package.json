{
  "name": "news-portal",
  "version": "1.0.0",
  "description": "A performance-audited News Portal application using Puppeteer and Lighthouse.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "setup": "npm install && npm run dev",
    "start": "node server.js",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:performance:prod": "npm run build && npm run preview -- --port 4000 & npm run test:performance",
    "test:performance": "node tests/performance/lighthouse-articles.test.js && node tests/performance/lighthouse-detail.test.js",
    "test:all": "npm install && npm run build && node tests/run-all.js"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "vite": "^5.4.21"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "lighthouse": "^12.1.0",
    "puppeteer": "^22.11.2"
  }
}
